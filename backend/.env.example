# Ollama host — use http://localhost:11434 when running locally,
# or http://host.docker.internal:11434 when running inside Docker
OLLAMA_HOST=http://localhost:11434

# Ollama model to use for file classification (must be pulled via `ollama pull <model>`)
OLLAMA_MODEL=llama3

# Allowed CORS origin for the frontend dev server
CORS_ORIGIN=http://localhost:5173

# History file path for undo/rollback (defaults to ~/.ai-file-sorter/history.json)
# HISTORY_FILE=~/.ai-file-sorter/history.json
